# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_API_KEY: Web API Key of your Firebase project.
# Set this to empty or your real API key if you want to use Firebase.
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY

# FIREBASE_DATABASE_URL: Base URL of your Firebase Realtime Database.
FIREBASE_DATABASE_URL=https://YOUR_DATABASE_NAME.firebaseio.com/

# Dograapy Payment Gateway & Razorpay integration
DOGRAPAY_API_KEY=dgpy_b4de5cc0eafd0061c38a993ca01c02f0c3a17d92f8d64f961e6844131f08e198
DOGRAPAY_PLATFORM_NAME=Tournament Arena
RAZORPAY_KEY_ID=rzp_live_default_key
